# Python virtual env
.venv/
venv/

# Byte-compiled / caches
__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Vendored pretrained weights (large binaries; copy from ../srs-benchmark/pretrain)
pretrain/

# LMDB databases (huge; see lmdb-storage-plan memory)
*_db/
train_db/
test_db/
label_filter_db/
*.mdb

# Compiled CUDA/C++ extension build artifacts
build/
*.so
*.pyd
*.dll
*.egg-info/

# Scratch / local outputs
result/
raw/
evaluation/
wandb/
*.log

# Rust build artifacts (regenerable)
target/

# Reference port artifacts: large + regenerable (keep ref_metrics.json + weight_names.json)
reference/*.safetensors
reference/trace_user_*.json
reference/rust_pred_*.json

# Model checkpoints (regenerable binaries; never track) + papers + any stray safetensors
*.pth
*.safetensors
*.pdf

# Large / transient scratch artifacts (regenerable): serialized tensors, compiled binaries,
# captured stdout logs, pre-tidy backups, and exported per-user reference traces. Keep the
# scripts + small configs in scratchpad/, drop these.
*.pt
*.exe
*.out
*.bak_pretidy
trace_user_*.json

# Mid-run learnable-codebook snapshots (one ~3.5 MB file per 500 steps per QAT run — 393 MiB
# of dead weight before 2026-07-15). Only the *final* codebooks matter (cb_wkv_final.txt /
# cb_shift_final.txt, referenced by champion_5k.json) and they don't match these patterns.
*_shiftcb_*.txt
*_wkvcb_*.txt
